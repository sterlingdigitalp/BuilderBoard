# BuilderBoard Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must never be committed.

# --- Provider Authentication ---
# Google OAuth is used for provider authentication.
# Create credentials at https://console.cloud.google.com/apis/credentials
BUILDERBOARD_GOOGLE_CLIENT_ID=
BUILDERBOARD_GOOGLE_CLIENT_SECRET=

# OpenAI ChatGPT OAuth is pre-configured with a built-in client ID.
# No environment variable is required for OpenAI ChatGPT authentication.

# --- Runtime Certification ---
# Command to execute during the runtime certification loop.
# When set, the certification loop runs this command against the launched
# application and records whether it succeeds. The command should send a
# Builder request and exit with status 0 on success.
# Example: BUILDERBOARD_RUNTIME_REQUEST_COMMAND='./scripts/test-basic-chat.sh'
# Optional. Without this, certification loop records request status as SKIPPED.
# BUILDERBOARD_RUNTIME_REQUEST_COMMAND=

# --- Development ---
# Override the directory where the packaged dev runtime is installed.
# Default: /Applications
# Example: BUILDERBOARD_DEV_INSTALL_DIR="$HOME/Applications"
# Optional.
# BUILDERBOARD_DEV_INSTALL_DIR=

# --- Diagnostics / Tracing ---
# Enable OpenAI execution tracing (set to "1" to enable).
# Traces are written to stdout/stderr or a trace directory.
# Optional.
# BUILDERBOARD_TRACE_OPENAI_EXECUTION=

# Enable native tool execution tracing (set to "1" to enable).
# When enabled, produces a comparison document at the trace path.
# Optional.
# BUILDERBOARD_TRACE_NATIVE_TOOLS=

# Directory for trace output files.
# Used when BUILDERBOARD_TRACE_NATIVE_TOOLS=1.
# Optional. Defaults to a system temp directory.
# BUILDERBOARD_TRACE_DIR=

# Enable runtime diagnostics (set to "1" to enable).
# Optional.
# BUILDERBOARD_TRACE_RUNTIME=
